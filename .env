# =============================================================================
# PRODUCTION — NEXT_PUBLIC_* vars are baked into the bundle at `next build`.
# These values are injected as Docker build args by the CI pipeline from
# GitHub Actions secrets. Do NOT commit real URLs here — use placeholders.
# The CI workflow reads NEXT_PUBLIC_* secrets and passes them as
# --build-arg to docker buildx.
# =============================================================================

NEXT_PUBLIC_API_GATEWAY_URL=https://api.quidpath.com
NEXT_PUBLIC_BILLING_URL=https://billing.quidpath.com
NEXT_PUBLIC_INVENTORY_URL=https://inventory.quidpath.com
NEXT_PUBLIC_CRM_URL=https://crm.quidpath.com
NEXT_PUBLIC_HRM_URL=https://hrm.quidpath.com
NEXT_PUBLIC_POS_URL=https://pos.quidpath.com
NEXT_PUBLIC_PROJECTS_URL=https://projects.quidpath.com
